# WiFi credentials — copy secrets.h.example to secrets.h and fill in your details
esp32_matrix_webserver/secrets.h

# Node.js dependencies — recreated by running: npm install
mcp_server/node_modules/

# TypeScript compiled output
mcp_server/dist/

# Local board URL override for MCP server (optional)
mcp_server/.env

# Arduino IDE temporary files
*.tmp.*

# Arduino "Export Compiled Binary" output — build artifacts, machine-specific, and
# (with a local secrets.h) the .bin has WiFi creds baked in. Never commit.
esp32_matrix_webserver/build/

# Claude Code — local/machine-specific settings (permissions, local overrides)
.claude/settings.local.json

# Superpowers local brainstorm/cache (machine-specific, not part of the repo)
.superpowers/

# .mcp.json contains machine-specific absolute paths; .claude/settings.json is the portable config
.mcp.json

# macOS
.DS_Store

# Windows
Thumbs.db

# Python bytecode cache (from running the claude-hooks resolver/parity tests)
__pycache__/
*.pyc

# Playwright MCP scratch output (browser snapshots/console logs)
.playwright-mcp/

# Release build output (merged firmware, manifest, .mcpb) — produced by scripts/build-release.mjs
release/

# Generated: shared engine copied into the MCP bundle for packing (see scripts/copy-shared-runtime.mjs)
mcp_server/shared-runtime/
# Generated: Studio tree staged into mcp_server/ for the .mcpb bundle
mcp_server/studio-dist/
# Engine's bound-port cache (written at runtime, machine-specific)
mcp_server/.engine-url
