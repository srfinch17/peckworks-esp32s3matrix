#pragma once

// WiFi credentials are no longer configured here.
//
// This project uses WiFiManager (tzapu) for runtime WiFi setup:
//   1. On first boot the board starts a hotspot named "ESP32-Matrix-Setup"
//   2. Connect to that network on any phone or laptop
//   3. Open 192.168.4.1 and enter your home WiFi credentials
//   4. The board saves them to flash and connects automatically from then on
//
// To reconfigure (e.g. new network), hold the BOOT button while powering on.
//
// This file is kept for reference only and is not included by the firmware.
