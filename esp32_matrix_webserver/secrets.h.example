#pragma once

// WiFi is normally configured at runtime via the WiFiManager portal:
//   1. On first boot the board starts a hotspot named "ESP32-Matrix-Setup"
//   2. Connect to that network on any phone or laptop
//   3. Open 192.168.4.1 and enter your home WiFi credentials
//   4. The board saves them and connects automatically from then on
//   (Hold BOOT ~1s while powering on to wipe creds and reconfigure.)
//
// OPTIONAL OVERRIDE — hardcoded credentials (diagnostic / escape hatch):
// Copy this file to secrets.h (gitignored) and uncomment the two defines below.
// When defined, the firmware connects with these directly and NEVER opens the
// portal — bypassing WiFiManager's credential handling entirely. Useful when
// portal-saved credentials misbehave (e.g. special characters in the password)
// or to rule the portal out while debugging connect failures.
//
// #define WIFI_SSID     "YourNetworkName"
// #define WIFI_PASSWORD "YourPassword"

// OPTIONAL OVERRIDE — MAC address:
// Present a different MAC to the network. Escape hatch for a router/mesh that
// has auto-blocklisted the board's real MAC (f0:f5:bd:75:29:3c) and offers no
// accessible device list to unblock it. The first byte must stay unicast +
// locally administered — the F2 prefix below is a safe choice.
//
// #define WIFI_MAC_OVERRIDE { 0xF2, 0xF5, 0xBD, 0x75, 0x29, 0x3C }
